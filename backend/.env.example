# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/hyper-local-library
MONGODB_TEST_URI=mongodb://localhost:27017/hyper-local-library-test

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=library_transactions

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Service Configuration
DELIVERY_RADIUS_KM=8
LATE_FEE_PER_DAY=10
GRACE_PERIOD_DAYS=2
DEFAULT_BORROW_PERIOD_DAYS=14

# AI API Configuration (To be configured)
AI_API_URL=http://localhost:8000/recommend
AI_API_KEY=your_ai_api_key

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Delivery Service API
DELIVERY_API_URL=https://api.delivery-partner.com
DELIVERY_API_KEY=your_delivery_api_key
